      "round 01 | cost=0.1659 eps=0.2225 alpha=0.6256\n",
      "round 02 | cost=0.1810 eps=0.2683 alpha=0.5016\n",
      "round 03 | cost=0.1895 eps=0.2717 alpha=0.4931\n",
      "round 04 | cost=0.1636 eps=0.2341 alpha=0.5928\n",
      "round 05 | cost=0.1882 eps=0.2663 alpha=0.5067\n",
